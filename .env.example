# ============================================
# SPLASH SIGNAL — Environment Variables
# ============================================

# GEMINI AI (required for narrative/AI features)
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=

# DATABASE (required for server-side features)
DATABASE_URL=postgresql://user:pass@localhost:5432/splashsignal

# REDIS (optional — enables caching and alert dedup)
REDIS_URL=redis://localhost:6379

# ============================================
# DATA SOURCES (add keys for live data)
# ============================================

# BIRDEYE — https://birdeye.so (free tier available)
# Used for: holder data, recent trades, wallet activity
# Without key: holder/trade data unavailable, app still works
VITE_BIRDEYE_API_KEY=

# HELIUS — https://helius.dev (free tier: 100k credits/mo)
# Used for: real-time Solana transactions, wallet monitoring
# Without key: real-time wallet tracking unavailable
VITE_HELIUS_API_KEY=

# SOLSCAN — https://pro-api.solscan.io (optional)
# Used for: supplemental holder data
# Without key: falls back to Birdeye for holders
VITE_SOLSCAN_API_KEY=

# DexScreener — NO KEY NEEDED (free public API)
# Token price, volume, new pairs — always available

# ============================================
# ANALYTICS (optional)
# ============================================
VITE_GA4_MEASUREMENT_ID=

# ============================================
# APP
# ============================================
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173
